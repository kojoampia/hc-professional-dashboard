{
  "name": "hc-professional-dashboard",
  "version": "0.0.1",
  "private": true,
  "description": "Health Connect Professional Dashboard",
  "license": "Apache-2.0",
  "scripts": {
    "app:start": "./mvnw",
    "app:up": "docker compose -f src/main/docker/app.yml up --wait",
    "backend:build-cache": "./mvnw dependency:go-offline -ntp",
    "backend:debug": "./mvnw -Dspring-boot.run.jvmArguments=\"-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:8000\"",
    "backend:doc:test": "./mvnw -ntp javadoc:javadoc --batch-mode",
    "backend:info": "./mvnw -ntp enforcer:display-info --batch-mode",
    "backend:nohttp:test": "./mvnw -ntp checkstyle:check --batch-mode",
    "backend:start": "./mvnw -Dskip.installnodenpm -Dskip.npm",
    "backend:unit:test": "./mvnw -ntp -Dskip.installnodenpm -Dskip.npm verify --batch-mode -Dlogging.level.ROOT=OFF -Dlogging.level.tech.jhipster=OFF -Dlogging.level.net.jojoaddison=OFF -Dlogging.level.org.springframework=OFF -Dlogging.level.org.springframework.web=OFF -Dlogging.level.org.springframework.security=OFF",
    "build": "npm run webapp:prod --",
    "build-watch": "concurrently 'npm run webapp:build:dev -- --watch' npm:backend:start",
    "ci:backend:test": "npm run backend:info && npm run backend:doc:test && npm run backend:nohttp:test && npm run backend:unit:test -- -P$npm_package_config_default_environment",
    "ci:e2e:package": "npm run java:$npm_package_config_packaging:$npm_package_config_default_environment -- -Pe2e -Denforcer.skip=true",
    "ci:e2e:prepare": "npm run ci:e2e:prepare:docker",
    "ci:e2e:prepare:docker": "npm run services:up --if-present && docker ps -a",
    "preci:e2e:server:start": "npm run services:db:await --if-present && npm run services:others:await --if-present",
    "ci:e2e:server:start": "java -jar target/e2e.$npm_package_config_packaging --spring.profiles.active=e2e,$npm_package_config_default_environment -Dlogging.level.ROOT=OFF -Dlogging.level.tech.jhipster=OFF -Dlogging.level.net.jojoaddison=OFF -Dlogging.level.org.springframework=OFF -Dlogging.level.org.springframework.web=OFF -Dlogging.level.org.springframework.security=OFF --logging.level.org.springframework.web=ERROR",
    "ci:e2e:teardown": "npm run ci:e2e:teardown:docker --if-present",
    "ci:e2e:teardown:docker": "docker compose -f src/main/docker/services.yml down -v && docker ps -a",
    "ci:frontend:build": "npm run webapp:build:$npm_package_config_default_environment",
    "ci:frontend:test": "npm run ci:frontend:build && npm test",
    "ci:server:await": "echo \"Waiting for services to start\" && npm run ci:server:await:hc-professional-dashboard && echo \"Services started\"",
    "ci:server:await:hc-professional-dashboard": "wait-on -t 180000 http-get://127.0.0.1:$npm_package_config_backend_port/management/health",
    "clean-www": "rimraf target/classes/static/",
    "cleanup": "rimraf target/",
    "deploy:dev": "npm run docker:build:dev && npm run docker:dev:tag && npm run docker:dev:push",
    "deploy:prod": "npm run docker:build:prod && npm run docker:prod:tag && npm run docker:prod:push",
    "docker:build:dev": "docker compose build",
    "docker:build:prod": "docker compose -f docker-compose-prod.yml build",
    "docker:db:down": "docker compose -f src/main/docker/mongodb.yml down -v",
    "docker:db:up": "docker compose -f src/main/docker/mongodb.yml up --wait",
    "docker:dev:all": "npm run docker:dev:up && npm run docker:dev:logs",
    "docker:dev:build": "docker compose build",
    "docker:dev:down": "docker compose down -v",
    "docker:dev:logs": "docker compose logs -f",
    "docker:dev:push": "docker push docker-registry.jojoaddison.net/hc-professional-dashboard:0.0.1",
    "docker:dev:tag": "docker tag hc-professional-dashboard:0.0.1 docker-registry.jojoaddison.net/hc-professional-dashboard:0.0.1",
    "docker:dev:up": "docker compose up -d",
    "docker:jhipster-registry:down": "docker compose -f src/main/docker/jhipster-registry.yml down -v",
    "docker:jhipster-registry:up": "docker compose -f src/main/docker/jhipster-registry.yml up --wait",
    "docker:kafka:down": "docker compose -f src/main/docker/kafka.yml down -v",
    "docker:kafka:up": "docker compose -f src/main/docker/kafka.yml up --wait",
    "docker:prod:push": "docker push docker-registry.jojoaddison.net/hc-professional-dashboard:latest",
    "docker:prod:tag": "docker tag hc-professional-dashboard:0.0.1 docker-registry.jojoaddison.net/hc-professional-dashboard:latest",
    "jest": "jest --coverage --logHeapUsage --maxWorkers=2 --config jest.conf.js",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky install",
    "prettier:check": "prettier --check \"{,src/**/,webpack/,.blueprint/**/}*.{md,json,yml,html,cjs,mjs,js,ts,tsx,css,scss,java}\"",
    "prettier:format": "prettier --write \"{,src/**/,webpack/,.blueprint/**/}*.{md,json,yml,html,cjs,mjs,js,ts,tsx,css,scss,java}\"",
    "rebuild:dev": "npm run docker:dev:build && npm run docker:dev:down && npm run docker:dev:up && npm run docker:dev:logs",
    "serve": "npm run start --",
    "services:up": "docker compose -f src/main/docker/services.yml up --wait",
    "start": "ng serve --hmr",
    "start-tls": "npm run webapp:dev-ssl",
    "pretest": "npm run lint",
    "test": "ng test --coverage --log-heap-usage -w=2",
    "test:watch": "npm run test -- --watch",
    "watch": "concurrently npm:start npm:backend:start",
    "webapp:build": "npm run clean-www && npm run webapp:build:dev",
    "webapp:build:dev": "ng build --configuration development",
    "webapp:build:prod": "ng build --configuration production",
    "webapp:dev": "ng serve",
    "webapp:dev-ssl": "ng serve --ssl",
    "webapp:dev-verbose": "ng serve --verbose",
    "webapp:prod": "npm run clean-www && npm run webapp:build:prod",
    "webapp:test": "npm run test --"
  },
  "config": {
    "backend_port": "5505",
    "default_environment": "prod",
    "packaging": "jar"
  },
  "resolutions": {
    "@angular/animations": "17.0.6",
    "@angular/cdk": "17.0.6",
    "@angular/cli": "17.0.6",
    "@angular/common": "17.0.6",
    "@angular/compiler": "17.0.6",
    "@angular/core": "17.0.6"
  },
  "dependencies": {
    "@angular/animations": "19.2.25",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "19.2.25",
    "@angular/compiler": "19.2.25",
    "@angular/core": "19.2.25",
    "@angular/forms": "19.2.25",
    "@angular/localize": "19.2.25",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "19.2.25",
    "@angular/platform-browser-dynamic": "19.2.25",
    "@angular/router": "19.2.25",
    "@fortawesome/angular-fontawesome": "^1.0.0",
    "@fortawesome/fontawesome-svg-core": "6.5.1",
    "@fortawesome/free-solid-svg-icons": "6.5.1",
    "@ng-bootstrap/ng-bootstrap": "^18.0.0",
    "@ngu/carousel": "^19.0.0",
    "@ngx-translate/core": "15.0.0",
    "@ngx-translate/http-loader": "8.0.0",
    "@popperjs/core": "2.11.8",
    "@swimlane/ngx-charts": "^23.1.0",
    "bootstrap": "5.3.2",
    "d3": "^7.8.5",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3.js": "^0.0.2-security",
    "dayjs": "1.11.10",
    "hammerjs": "^2.0.8",
    "ngx-infinite-scroll": "^19.0.0",
    "ngx-webstorage": "^19.0.1",
    "rxjs": "7.8.1",
    "sockjs-client": "^1.6.1",
    "tslib": "2.6.2",
    "webstomp-client": "^1.2.6",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^19.0.1",
    "@angular-builders/jest": "^19.0.1",
    "@angular-devkit/build-angular": "19.2.27",
    "@angular-eslint/eslint-plugin": "^19.8.1",
    "@angular/cli": "19.2.27",
    "@angular/compiler-cli": "19.2.25",
    "@angular/service-worker": "19.2.25",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/d3": "^7.4.3",
    "@types/hammerjs": "^2.0.45",
    "@types/jest": "29.5.11",
    "@types/node": "^18.19.3",
    "@types/sockjs-client": "^1.5.4",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "browser-sync": "3.0.4",
    "browser-sync-webpack-plugin": "2.3.0",
    "buffer": "6.0.3",
    "concurrently": "8.2.2",
    "copy-webpack-plugin": "11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-webpack-plugin": "4.0.1",
    "folder-hash": "4.0.4",
    "generator-jhipster": "8.1.0",
    "husky": "8.0.3",
    "jest": "29.7.0",
    "jest-date-mock": "1.0.8",
    "jest-environment-jsdom": "29.7.0",
    "jest-junit": "16.0.0",
    "jest-preset-angular": "^14.6.2",
    "jest-sonar": "0.2.16",
    "lint-staged": "15.2.0",
    "merge-jsons-webpack-plugin": "2.0.1",
    "postcss": "^8.5.20",
    "prettier": "3.1.0",
    "prettier-plugin-java": "2.5.0",
    "prettier-plugin-packagejson": "2.4.7",
    "rimraf": "5.0.5",
    "swagger-ui-dist": "5.10.3",
    "tailwindcss": "^4.3.3",
    "ts-jest": "29.1.1",
    "typescript": "5.5.4",
    "wait-on": "7.2.0",
    "webpack-bundle-analyzer": "4.10.1",
    "webpack-merge": "5.10.0",
    "webpack-notifier": "1.15.0"
  },
  "engines": {
    "node": ">=18.18.2"
  },
  "cacheDirectories": [
    "node_modules"
  ],
  "overrides": {
    "webpack": "5.89.0"
  }
}
